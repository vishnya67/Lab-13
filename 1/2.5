def read_in_chunks(total_size, chunk_size=1024):
    bytes_read = 0

    while bytes_read < total_size:
        current_chunk_size = min(chunk_size, total_size - bytes_read)
        yield 'A' * current_chunk_size
        bytes_read += current_chunk_size

chunks = list(read_in_chunks(2500, 1000))
print(chunks)
